# ─── StockTerrain 配置 ────────────────────────────────────
# 复制为 .env 后按需修改

# ═══ LLM 配置（辩论/分析功能必填，3D 地形不需要）═══════════

# 是否启用 LLM 功能 (true/false)
LLM_ENABLED=false

# LLM 提供商类型: openai_compatible | anthropic
LLM_PROVIDER=openai_compatible

# API Key（必填，从对应厂商获取）
LLM_API_KEY=

# API Base URL（不同厂商的地址）
# OpenAI:      https://api.openai.com/v1
# DeepSeek:    https://api.deepseek.com/v1
# 通义千问:    https://dashscope.aliyuncs.com/compatible-mode/v1
# Kimi:        https://api.moonshot.cn/v1
# 智谱GLM:     https://open.bigmodel.cn/api/paas/v4
# Anthropic:   https://api.anthropic.com
LLM_BASE_URL=https://api.openai.com/v1

# 模型名称
LLM_MODEL=gpt-4o-mini

# 生成参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ═══ 数据源配置 ═══════════════════════════════════════════

# Tushare Pro（可选，提供补充数据）
# 注册获取 token: https://tushare.pro/register
# TUSHARE_TOKEN=

# ═══ Redis 配置（可选，不配置时退化为内存缓存）═════════════

# REDIS_ENABLED=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# ═══ 服务配置 ═══════════════════════════════════════════════

# 后端端口
# SERVER_PORT=8000

# CORS 允许的前端域名（逗号分隔）
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
