# ─── StockScape 生产环境配置模板 ─────────────────────────
# 复制为 .env.production 后按实际服务器环境修改

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=false
CORS_ORIGINS=https://stockscape.example.com

# 前端公开 API 地址
# 若通过 Nginx 同源代理，保持为空即可
NEXT_PUBLIC_API_BASE=

# 数据持久化
CHROMADB_PERSIST_DIR=/app/data/chromadb
RAG_PERSIST_DIR=/app/data/chromadb_rag

# Redis（可选）
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Cloudflare Tunnel（可选）
CLOUDFLARE_TUNNEL_TOKEN=

# LLM
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
